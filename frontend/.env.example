# Frontend environment variables (Vite). Copy to .env.local and adjust.

# Base URL for API requests in production builds. Leave empty in dev so that
# requests stay relative and the Vite dev proxy forwards them to the backend.
# Example: VITE_API_BASE=https://api.example.com
VITE_API_BASE=

# Backend target for the Vite dev proxy (used by `npm run dev` only).
# Defaults to http://localhost:8502 when unset.
VITE_DEV_PROXY_TARGET=http://localhost:8502

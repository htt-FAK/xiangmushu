# 复制为 .env 后填写
# 复星 AI 网关（OpenAI 兼容，聊天/视觉优先）；不设则使用 config 内私库默认，或显式置空禁用网关
FOSUN_AIGW_BASE_URL=https://aigw.fosunwealth.com/v1
# FOSUN_AIGW_API_KEY=

# 百炼（推荐）：嵌入与网关失败 / enable_search 回落；优先使用 DASHSCOPE_API_KEY
DASHSCOPE_API_KEY=
# 兼容：仅配置此项也可（与上二选一或同时配置时优先百炼）
OPENAI_API_KEY=
# 无网关时聊天默认 https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL=

# Streamlit 运行时是否在终端打印业务日志（默认关）
# APP_CONSOLE_LOG=1

# 嵌入专用 base（默认百炼 compatible-mode，不随聊天网关变）
# EMBEDDING_OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3

# 场景模型（leaderboard v2026.05.21 · 优先复星网关 ID；聊天走 FOSUN_AIGW_*，嵌入仍百炼）
# 联网补料 / 模板视觉 / 表格多模态：fosun G_doc 最高 qwen3.6-plus
VISION_WEB_MODEL=qwen3.6-plus
TEMPLATE_VISION_MODEL=qwen3.6-plus
VISION_EXTRACT_MODEL=qwen3.6-plus
TABLE_CELL_VISION_MODEL=qwen3.6-plus
TABLE_CELL_FALLBACK_MODEL=qwen3.5-plus
# 强 RAG 短文 / 模板 JSON 分析 / 表格快批
SMALL_LLM_MODEL=kimi-k2.6
# 结构分析：复星网关上 glm-5.1 易卡住/空回复，推荐 qwen3.5-plus
TEMPLATE_ANALYZE_MODEL=qwen3.5-plus
# TEMPLATE_ANALYZE_FALLBACK_MODEL=qwen3.6-plus
# TEMPLATE_ANALYZE_TIMEOUT=90
BATCH_TABLE_FAST_MODEL=kimi-k2.6
# 复星 chat 不可靠模型列表（逗号分隔）：直连百炼，避免网关空回复
# FOSUN_CHAT_SKIP_MODELS=glm-5.1,glm-5,kimi-k2.6,kimi-k2.5
# 弱库关联网、长段正文
LARGE_LLM_MODEL=qwen3.6-plus
# 审核 Agent（次选回落 glm-5.1 / qwen3.5-plus）
AUDIT_LLM_MODEL=qwen3.6-plus

# 温度（可选）
TEMP_VISION=0.25
TEMP_WEB_GEN=0.4
TEMP_SMALL_LLM=0.1
TEMP_TEMPLATE_ANALYZE=0.1
TEMP_LARGE_LLM=0.65
TEMP_AUDIT=0.2

# OpenAI：单次请求超时（秒）与 SDK 内重试次数
OPENAI_TIMEOUT=180
OPENAI_MAX_RETRIES=4

# 入库时每批最多 chunk 数
EMBED_ADD_BATCH_SIZE=12

# 检索最大距离
RETRIEVAL_MAX_DISTANCE=1.25

# 模板视觉（可选）
# TEMPLATE_VISION_MAX_PAGES=4
# TEMPLATE_VISION_MAX_LONG_EDGE=1280
# TEMPLATE_VISION_API_TIMEOUT=120
# 表格批量快速模式（默认开）：不 enable_search、不传页图
# BATCH_TABLE_FAST=1
# BATCH_TABLE_FAST_MODEL=glm-5.1
# 深度思考仅百炼 compatible-mode 传 enable_thinking=False；复星网关不支持该参数
# TEMPLATE_VISION_ENABLED=0

# 表格多模态
# TABLE_CELL_VISION=1
# TABLE_VISION_MAX_PAGES=4

# 摘要正文字数下限（任意含「摘要」章节）
# ABSTRACT_WORD_LIMIT=650
# 弱库未开联网时仍批量填表（默认开）
# BATCH_TABLE_ALLOW_WEAK_KB=1

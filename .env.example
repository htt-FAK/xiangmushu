# 复制为 .env 后填写
# 百炼（推荐）：与官方示例一致，优先使用 DASHSCOPE_API_KEY
DASHSCOPE_API_KEY=
# 兼容：仅配置此项也可（与上二选一或同时配置时优先百炼）
OPENAI_API_KEY=
# 默认 https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL=

# Embedding（百炼需换为对应 text-embedding 模型名）
# 百炼 compatible-mode 常用 text-embedding-v3；OpenAI 官方站则用 text-embedding-3-small 等
EMBEDDING_MODEL=text-embedding-v3

# 场景模型（默认值已按产品约定，可按需覆盖）
VISION_WEB_MODEL=qwen3.5-plus-2026-04-20
SMALL_LLM_MODEL=qwen3.6-flash-2026-04-16
LARGE_LLM_MODEL=deepseek-v4-pro
# 兼容旧名：未设 VISION_WEB_MODEL 时可读 VISION_MODEL
# VISION_MODEL=

# 温度（可选）
TEMP_VISION=0.25
TEMP_WEB_GEN=0.4
TEMP_SMALL_LLM=0.1
TEMP_LARGE_LLM=0.65

# OpenAI：单次请求超时（秒）与 SDK 内重试次数
OPENAI_TIMEOUT=180
OPENAI_MAX_RETRIES=4

# 入库时每批最多 chunk 数（越小单次 embedding 越快，总批次数会增加）
EMBED_ADD_BATCH_SIZE=12

# 检索最大距离
RETRIEVAL_MAX_DISTANCE=1.25

# 可选：Tavily 联网摘要（https://tavily.com）
TAVILY_API_KEY=

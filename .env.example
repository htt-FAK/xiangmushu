# 复制为 .env 后填写

# DeepSeek（大需求文本生成：deepseek-v4-pro）
DEEPSEEK_API_KEY=

# 阿里云百炼（小需求文本 + 视觉：qwen3.6-flash / qwen3.6-plus）
# 优先使用 DASHSCOPE_API_KEY
DASHSCOPE_API_KEY=
# 兼容：仅配置此项也可（与上二选一或同时配置时优先百炼）
OPENAI_API_KEY=
# 无网关时聊天默认 https://dashscope.aliyuncs.com/api/v2/apps/protocols/compatible-mode/v1
OPENAI_BASE_URL=

# Streamlit 运行时是否在终端打印业务日志（默认关）
# APP_CONSOLE_LOG=1

# 嵌入专用 base（默认百炼 compatible-mode，不随聊天网关变）
# EMBEDDING_OPENAI_BASE_URL=https://dashscope.aliyuncs.com/api/v2/apps/protocols/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3

# ---- 场景模型 ----
# 视觉 / 联网 / 表格多模态：qwen3.6-plus-2026-04-02
VISION_WEB_MODEL=qwen3.6-plus-2026-04-02
TEMPLATE_VISION_MODEL=qwen3.6-plus-2026-04-02
VISION_EXTRACT_MODEL=qwen3.6-plus-2026-04-02
TABLE_CELL_VISION_MODEL=qwen3.6-plus-2026-04-02
TABLE_CELL_FALLBACK_MODEL=qwen3.6-flash
# 小需求文本 / 表格快批：deepseek-chat
SMALL_LLM_MODEL=deepseek-chat
BATCH_TABLE_FAST_MODEL=deepseek-chat
TABLE_CELL_FALLBACK_MODEL=deepseek-chat
# 大需求文本 / 结构分析 / 审核：deepseek-v4-pro
TEMPLATE_ANALYZE_MODEL=deepseek-v4-pro
LARGE_LLM_MODEL=deepseek-v4-pro
AUDIT_LLM_MODEL=deepseek-v4-pro

# 温度（可选）
TEMP_VISION=0.25
TEMP_WEB_GEN=0.4
TEMP_SMALL_LLM=0.1
TEMP_TEMPLATE_ANALYZE=0.1
TEMP_LARGE_LLM=0.65
TEMP_AUDIT=0.2

# OpenAI：单次请求超时（秒）与 SDK 内重试次数
OPENAI_TIMEOUT=180
OPENAI_MAX_RETRIES=4

# 入库时每批最多 chunk 数
EMBED_ADD_BATCH_SIZE=12

# 检索最大距离
RETRIEVAL_MAX_DISTANCE=1.25

# 模板视觉（可选）
# TEMPLATE_VISION_MAX_PAGES=4
# TEMPLATE_VISION_MAX_LONG_EDGE=1280
# TEMPLATE_VISION_API_TIMEOUT=120
# 表格批量快速模式（默认开）：不 enable_search、不传页图
# BATCH_TABLE_FAST=1
# BATCH_TABLE_FAST_MODEL=qwen3.6-flash-2026-04-16
# 深度思考：DeepSeek 用 thinking.type=disabled，百炼用 enable_thinking=False 统一关闭
# TEMPLATE_VISION_ENABLED=0

# 表格多模态
# TABLE_CELL_VISION=1
# TABLE_VISION_MAX_PAGES=4

# 摘要正文字数下限（任意含「摘要」章节）
# ABSTRACT_WORD_LIMIT=650
# 弱库未开联网时仍批量填表（默认开）
# BATCH_TABLE_ALLOW_WEAK_KB=1

# Copy this file to `.env` and fill in your keys.

# Prefer DashScope-compatible credentials for this project.
DASHSCOPE_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Optional: dedicated embedding base. Defaults to DashScope compatible mode.
# EMBEDDING_OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3

# ---- Model defaults ----
# Large text generation fallback chain
LARGE_LLM_MODEL=qwen3.7-max-preview
FALLBACK_LLM_MODEL_1=qwen3.7-max-2026-05-17
FALLBACK_LLM_MODEL_2=qwen3.7-max-2026-05-20
FALLBACK_LLM_MODEL_3=qwen3.7-max

# Small / web generation fallback chain
SMALL_LLM_MODEL=qwen3.6-flash
SMALL_LLM_FALLBACK_MODEL=qwen3.6-35b-a3b
VISION_WEB_MODEL=qwen3.6-flash
VISION_WEB_FALLBACK_MODEL=qwen3.6-35b-a3b
BATCH_TABLE_FAST_MODEL=qwen3.6-flash
TABLE_CELL_FALLBACK_MODEL=qwen3.6-35b-a3b

# Template analysis
TEMPLATE_ANALYZE_MODEL=qwen3.6-flash
TEMPLATE_ANALYZE_FALLBACK_MODEL=qwen3.6-35b-a3b

# Vision / multimodal fallback chain
TEMPLATE_VISION_MODEL=qwen3.6-plus-2026-04-02
TEMPLATE_VISION_FALLBACK_MODEL=qwen3.7-plus-2026-05-26
VISION_EXTRACT_MODEL=qwen3.6-plus-2026-04-02
VISION_EXTRACT_FALLBACK_MODEL=qwen3.7-plus-2026-05-26
TABLE_CELL_VISION_MODEL=qwen3.6-plus-2026-04-02
TABLE_CELL_VISION_FALLBACK_MODEL=qwen3.7-plus-2026-05-26
VISUAL_AUDIT_MODEL=qwen3.6-plus-2026-04-02
VISUAL_AUDIT_FALLBACK_MODEL=qwen3.7-plus-2026-05-26

# Audit chain
AUDIT_LLM_MODEL=qwen3.7-max-preview
AUDIT_FALLBACK_1=qwen3.7-max-2026-05-17
AUDIT_FALLBACK_2=qwen3.7-max-2026-05-20
AUDIT_FALLBACK_3=qwen3.7-max

# Temperatures
TEMP_VISION=0.25
TEMP_WEB_GEN=0.4
TEMP_SMALL_LLM=0.1
TEMP_TEMPLATE_ANALYZE=0.1
TEMP_LARGE_LLM=0.65
TEMP_AUDIT=0.2

# Client behavior
OPENAI_TIMEOUT=180
OPENAI_MAX_RETRIES=4
EMBED_ADD_BATCH_SIZE=12
RETRIEVAL_MAX_DISTANCE=1.25

# Email auth
AUTH_DB_PATH=data/auth.sqlite3
AUTH_JWT_SECRET=change-me-to-a-long-random-secret
AUTH_JWT_EXPIRE_MINUTES=1440
AUTH_CODE_TTL_MINUTES=10

# Structured persistence
# sqlite = current compatibility mode; mysql = use the MySQL schema/migration path.
PERSISTENCE_MODE=sqlite
PERSISTENCE_SQLITE_FALLBACK=1
DATABASE_URL=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=xiangmushu
MYSQL_PASSWORD=
MYSQL_DATABASE=xiangmushu
MYSQL_CHARSET=utf8mb4
MYSQL_CONNECT_TIMEOUT=5
MYSQL_READ_TIMEOUT=30
MYSQL_WRITE_TIMEOUT=30
MYSQL_AUTO_CREATE_DATABASE=1
MYSQL_AUTO_MIGRATE=1
MYSQL_MIGRATIONS_DIR=migrations/mysql
# Stable key used to encrypt user-owned Bailian API keys at rest.
# Can be a Fernet key or any long random secret that will be derived.
USER_API_KEY_ENCRYPTION_KEY=change-me-to-a-stable-long-random-secret
# Optional SMTP. If unset, verification codes are logged for local development.
# AUTH_SMTP_HOST=smtp.example.com
# AUTH_SMTP_PORT=587
# AUTH_SMTP_USERNAME=
# AUTH_SMTP_PASSWORD=
# AUTH_SMTP_FROM=
# AUTH_SMTP_USE_TLS=1

# Optional switches
# TEMPLATE_VISION_MAX_PAGES=4
# TEMPLATE_VISION_MAX_LONG_EDGE=1280
# TEMPLATE_VISION_API_TIMEOUT=120
# TEMPLATE_VISION_ENABLED=0
# TABLE_CELL_VISION=1
# TABLE_VISION_MAX_PAGES=4
# BATCH_TABLE_FAST=1
# ABSTRACT_WORD_LIMIT=650
# BATCH_TABLE_ALLOW_WEAK_KB=1

# Artifact storage
# local = keep files under ARTIFACT_LOCAL_ROOT; tencent_cos = use Tencent COS.
STORAGE_PROVIDER=local
ARTIFACT_LOCAL_ROOT=data/artifacts

# Tencent COS. Keep bucket private and download through backend signed URLs.
# COS_BUCKET=your-bucket-appid
# COS_REGION=ap-guangzhou
# COS_ENDPOINT=your-bucket-appid.cos.ap-guangzhou.myqcloud.com
# COS_SECRET_ID=
# COS_SECRET_KEY=
# COS_PREFIX=prod/
# COS_PRIVATE=1
# COS_SIGNED_URL_EXPIRE_SECONDS=600

# Copy this file to `.env` and fill in your own credentials.
# Do NOT commit the real `.env` file.

# ===== LLM / API =====
DASHSCOPE_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Falls back to DASHSCOPE_API_KEY when empty.
OPENAI_API_KEY=

OPENAI_TIMEOUT=300
OPENAI_MAX_RETRIES=4
EMBEDDING_MODEL=text-embedding-v3
EMBED_ADD_BATCH_SIZE=8
APP_CONSOLE_LOG=1

# ===== Persistence =====
PERSISTENCE_MODE=mysql
PERSISTENCE_SQLITE_FALLBACK=1

# MySQL 数据库配置
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
MYSQL_CHARSET=utf8mb4
MYSQL_CONNECT_TIMEOUT=5
MYSQL_READ_TIMEOUT=30
MYSQL_WRITE_TIMEOUT=30
MYSQL_AUTO_CREATE_DATABASE=1
MYSQL_AUTO_MIGRATE=1
MYSQL_MIGRATIONS_DIR=migrations/mysql

# ===== Model Routing =====
VISION_WEB_MODEL=qwen3.7-plus
TEMPLATE_VISION_MODEL=qwen3.7-plus
VISION_EXTRACT_MODEL=qwen3.7-plus
TABLE_CELL_VISION_MODEL=qwen3.7-plus

TABLE_CELL_FALLBACK_MODEL=qwen3.7-plus
SMALL_LLM_MODEL=qwen3.7-plus
BATCH_TABLE_FAST_MODEL=qwen3.7-plus

TEMPLATE_ANALYZE_MODEL=qwen3.7-plus
LARGE_LLM_MODEL=qwen3.7-plus
AUDIT_LLM_MODEL=qwen3.7-plus

# ===== SMTP / Auth =====
AUTH_SMTP_HOST=smtp.qq.com
AUTH_SMTP_PORT=587
AUTH_SMTP_USERNAME=
AUTH_SMTP_PASSWORD=
AUTH_SMTP_FROM=
AUTH_SMTP_USE_TLS=1

AUTH_DB_PATH=data/auth.sqlite3
# Generate a strong random secret, e.g. `python -c "import secrets;print(secrets.token_urlsafe(32))"`
AUTH_JWT_SECRET=
AUTH_JWT_EXPIRE_MINUTES=1440
AUTH_CODE_TTL_MINUTES=10

# Encryption key for stored user API keys (Fernet/urlsafe base64).
USER_API_KEY_ENCRYPTION_KEY=

# ===== Artifact Storage =====
STORAGE_PROVIDER=tencent_cos
ARTIFACT_LOCAL_ROOT=data/artifacts

COS_BUCKET=
COS_REGION=
COS_ENDPOINT=
COS_SECRET_ID=
COS_SECRET_KEY=
COS_PREFIX=prod/
COS_PRIVATE=1
COS_SIGNED_URL_EXPIRE_SECONDS=600

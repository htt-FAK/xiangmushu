# 复制为 .env 后填写
# 复星 AI 网关（OpenAI 兼容，聊天/视觉优先）；不设则使用 config 内私库默认，或显式置空禁用网关
# FOSUN_AIGW_BASE_URL=https://aigw.fosunwealth.com/v1
# FOSUN_AIGW_API_KEY=
# 百炼（推荐）：嵌入与网关失败回落；优先使用 DASHSCOPE_API_KEY
DASHSCOPE_API_KEY=
# 兼容：仅配置此项也可（与上二选一或同时配置时优先百炼）
OPENAI_API_KEY=
# 无网关时聊天默认 https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL=
# Streamlit 运行时是否在终端打印业务日志（默认关；与 smoke 脚本的 print 不同）
# APP_CONSOLE_LOG=1

# 嵌入专用 OpenAI 兼容 base（默认与百炼 compatible-mode 一致，不随聊天网关变）
# EMBEDDING_OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Embedding（百炼需换为对应 text-embedding 模型名）
# 百炼 compatible-mode 常用 text-embedding-v3；OpenAI 官方站则用 text-embedding-3-small 等
EMBEDDING_MODEL=text-embedding-v3

# 场景模型（默认与 config.py 复星网关 ID 一致；网关若未上架 gpt-5.5 可改为 gpt-5.4 等）
# VISION_WEB_MODEL：弱知识库且开启「联网补料」时调用；须在网关侧支持 extra_body.enable_search
VISION_WEB_MODEL=qwen3.6-plus
# 模板 PDF 整页视觉 → JSON（默认 qwen3.6-plus，与「视觉审查」一致；应用层已关深度思考）
# TEMPLATE_VISION_MODEL=qwen3.6-plus
# 单图入库描述（向量检索用）
# VISION_EXTRACT_MODEL=gemini-3-pro
SMALL_LLM_MODEL=qwen3.6-plus
# 模板结构分析（纯文本 JSON，无 {{锚点}} 时；默认可用较快模型）
TEMPLATE_ANALYZE_MODEL=deepseek-v4-pro
LARGE_LLM_MODEL=gpt-5.4
# 兼容旧名：未设 VISION_WEB_MODEL 时可读 VISION_MODEL
# VISION_MODEL=
AUDIT_LLM_MODEL=deepseek-v4-pro
# 带图 table_cell 多模态（非联网批量）；联网批量仍用 VISION_WEB_MODEL
# TABLE_CELL_VISION_MODEL=gemini-3-pro

# 温度（可选）
TEMP_VISION=0.25
TEMP_WEB_GEN=0.4
TEMP_SMALL_LLM=0.1
TEMP_TEMPLATE_ANALYZE=0.1
TEMP_LARGE_LLM=0.65
TEMP_AUDIT=0.2

# OpenAI：单次请求超时（秒）与 SDK 内重试次数
OPENAI_TIMEOUT=180
OPENAI_MAX_RETRIES=4

# 入库时每批最多 chunk 数（越小单次 embedding 越快，总批次数会增加）
EMBED_ADD_BATCH_SIZE=12

# 检索最大距离
RETRIEVAL_MAX_DISTANCE=1.25

# 模板视觉：PDF 栅格化页数与缩放；缓存目录 data/.cache/template_vision/<hash>/
# TEMPLATE_VISION_MAX_PAGES=4
# TEMPLATE_VISION_ZOOM=1.2
# TEMPLATE_VISION_MAX_LONG_EDGE=1280
# TEMPLATE_VISION_API_TIMEOUT=120
# TEMPLATE_VISION_ENABLED=0
# SOFFICE_CONVERT_TIMEOUT=180

# 表格生成：附带模板页 PNG 多模态（1=开）；TABLE_VISION_MAX_PAGES 限制每格附带页数
# TABLE_CELL_VISION=1
# TABLE_VISION_MAX_PAGES=6
# 填充后正文首行缩进（pt），约 2 字宽；0 关闭
# BODY_FIRST_LINE_INDENT_PT=24

# 性能优化配置
# 并行任务数（同时进行的LLM调用数，建议4-8）
MAX_PARALLEL_TASKS=4
# 是否启用查询缓存（相同query复用结果，0=关/1=开）
ENABLE_QUERY_CACHE=1
# 查询缓存大小限制（条）
QUERY_CACHE_SIZE=100
# 是否启用审核（0=关/1=开，关闭可大幅加速）
ENABLE_AUDIT=1
# 批量表格单元格上限（同行多个单元格合并为一次调用）
BATCH_MAX_CELLS=8